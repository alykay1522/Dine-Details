# Leave empty for same-origin /api on Vercel.
# Local dev: leave empty — Vite proxies /api to http://127.0.0.1:3001 automatically.
# Set only if the API runs on a different host/port (e.g. VITE_API_ORIGIN=http://localhost:3001).
VITE_API_ORIGIN=

# Optional: override dev API proxy target (default http://127.0.0.1:3001).
# VITE_DEV_API_PROXY=http://127.0.0.1:3001

# Set to true only for offline UI preview without a database. Never use in production.
VITE_USE_API_SHIMS=false
