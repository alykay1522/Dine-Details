{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/db push-force && pnpm -C artifacts/api-server build && pnpm -C artifacts/restaurant-site build",
  "outputDirectory": "artifacts/restaurant-site/dist/public",
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
