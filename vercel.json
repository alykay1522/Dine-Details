{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -C artifacts/api-server build && pnpm -C artifacts/restaurant-site build",
  "outputDirectory": "artifacts/restaurant-site/dist/public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
